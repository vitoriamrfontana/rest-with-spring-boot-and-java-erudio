	<query language="SQL"><![CDATA[SELECT
 	id,
 	author,
 	launch_date AS launchDate,
 	price,
 	title
FROM books b
JOIN person_books pb ON pb.book_id = b.id
WHERE pb.person_id = 1]]></query>
